# ========================================
# PIA — Environment Variables
# ========================================
# Copy this file to .env and fill in values

# Google Gemini API Key (required)
# Get from: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# MongoDB (optional — set USE_MONGODB=true to enable)
USE_MONGODB=false
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pia_db

# Structured data fallback (when USE_MONGODB=false)
JSON_STORE_DIR=./json_data

# Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2

# Retrieval Configuration
DENSE_WEIGHT=0.5
BM25_WEIGHT=0.5
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# Chunking Configuration
CHUNK_SIZE_INTERVIEW=512
CHUNK_OVERLAP_INTERVIEW=64
CHUNK_SIZE_JD=768
CHUNK_OVERLAP_JD=128
CHUNK_SIZE_APTITUDE=1024
CHUNK_OVERLAP_APTITUDE=128

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
